{
  "id": "transcript",
  "name": "视频文案归档",
  "description": "输入视频链接 → 自动下载 → 提取音频转文字（必剪 BcutASR）→ 文案归档入库（SQLite），按视频标题命名，可自由改名。编排现有 download + asr 两个本机服务。",
  "version": "1.0.0",
  "category": "text",

  "input_schema": {
    "url": {
      "type": "string",
      "required": true,
      "max_length": 2000,
      "label": "视频链接",
      "description": "支持 yt-dlp 覆盖的站点：B站 / YouTube / 抖音 等"
    },
    "title": {
      "type": "string",
      "required": false,
      "max_length": 200,
      "default": "",
      "label": "自定义标题",
      "description": "留空则用视频原标题；入库后仍可随时改名"
    },
    "quality": {
      "type": "enum",
      "options": ["audio", "best", "1080", "720", "480", "360"],
      "default": "audio",
      "required": false,
      "label": "下载清晰度",
      "description": "文案场景默认只下音频，最快最省；需要留存视频再选清晰度"
    },
    "cookiesFromBrowser": {
      "type": "enum",
      "options": ["", "edge", "chrome", "firefox"],
      "default": "",
      "required": false,
      "label": "浏览器 Cookies",
      "description": "需登录或有风控的站点（如 B站 412）选本机已登录浏览器"
    },
    "proxy": {
      "type": "string",
      "required": false,
      "max_length": 200,
      "label": "代理地址",
      "description": "如 http://127.0.0.1:7890"
    }
  },

  "output_schema": {
    "job_id": {
      "type": "string",
      "label": "任务 ID"
    },
    "status_url": {
      "type": "string",
      "label": "进度查询路径"
    },
    "archive_id": {
      "type": "number",
      "label": "归档记录 ID"
    },
    "title": {
      "type": "string",
      "label": "归档标题"
    },
    "text": {
      "type": "string",
      "label": "文案（TXT）"
    },
    "files": {
      "type": "file[]",
      "label": "下载文件（txt/srt）"
    }
  },

  "ui_hint": {
    "form_layout": "vertical",
    "icon": "archive",
    "estimated_time_seconds": 120,
    "service_panel": true
  },

  "runtime": {
    "async": true,
    "queue": "local-io",
    "timeout_seconds": 1800
  },

  "capabilities": [
    {
      "id": "run-core",
      "desc": "主 endpoint：链接→下载→转写→归档，返回 job_id",
      "kind": "core",
      "must_keep": true,
      "endpoints": ["POST /run"],
      "verify": { "manual": "先启动 download+asr 下游，POST /run {url} 应产生 job 并最终归档；宿主须透传 quality/cookiesFromBrowser/proxy" }
    },
    {
      "id": "job-progress",
      "desc": "任务进度（下载→转写→归档）与列表",
      "kind": "aux",
      "must_keep": true,
      "endpoints": ["GET /jobs/{id}", "GET /jobs"],
      "verify": { "method": "GET", "path": "/jobs", "expect": { "status": 200 } }
    },
    {
      "id": "archive-crud",
      "desc": "归档库：列表/搜索、详情、改名/改正文、删除（SQLite）",
      "kind": "aux",
      "must_keep": true,
      "endpoints": ["GET /archives", "GET /archives/{id}", "PATCH /archives/{id}", "DELETE /archives/{id}"],
      "verify": { "method": "GET", "path": "/archives", "expect": { "status": 200 } }
    },
    {
      "id": "rename-sync-download",
      "desc": "改名/删除会同步重命名/删除落盘 txt/srt；下载 /archives/{id}/download?fmt=txt|srt",
      "kind": "aux",
      "must_keep": true,
      "endpoints": ["GET /archives/{id}/download"],
      "verify": { "manual": "改名后 outputs/ 文件应同步重命名；DELETE 归档应连带删文件" }
    },
    {
      "id": "cookie-passthrough",
      "desc": "Cookie 管理透传到下载服务(:8789)：sites/login/save/close/list/file。宿主必须一并代理 /cookies/*",
      "kind": "aux",
      "must_keep": true,
      "endpoints": ["GET /cookies/sites", "POST /cookies/login", "POST /cookies/save", "POST /cookies/close", "GET /cookies/list", "DELETE /cookies/file"],
      "verify": { "manual": "启动 download 后 GET /cookies/sites 应经本服务透传返回站点列表；确认宿主已代理 /cookies/*（易漏）" }
    },
    {
      "id": "downstream-health",
      "desc": "下游发现与健康：/health.downstream 反映 download/asr 是否在线",
      "kind": "aux",
      "must_keep": true,
      "endpoints": ["GET /health"],
      "verify": { "method": "GET", "path": "/health", "expect": { "status": 200, "jsonHas": "downstream" } }
    },
    {
      "id": "health-probe",
      "desc": "健康检查：service===video_transcript",
      "kind": "invariant",
      "must_keep": true,
      "endpoints": ["GET /health"],
      "verify": { "method": "GET", "path": "/health", "expect": { "status": 200, "jsonEquals": { "service": "video_transcript" } } }
    }
  ],

  "local": {
    "label": "video_transcript",
    "defaultPort": 8799,
    "maxTries": 15,
    "envPort": "TRANSCRIPT_PORT",
    "healthPath": "/health",
    "endpoint": { "method": "POST", "path": "/run" },
    "start": {
      "windows": { "script": "start_api.ps1", "runtime": "powershell" }
    },
    "proxy": [
      {
        "prefix": "/transcript-api",
        "rewrite": { "pattern": "^/transcript-api", "replacement": "" }
      },
      {
        "prefix": "/transcript-health",
        "pathEquals": true,
        "rewrite": { "pattern": "^/transcript-health$", "replacement": "/health" }
      }
    ]
  }
}
